yourdomain.com {
    # API requests -> backend (Hono, port 3000)
    handle /api/* {
        reverse_proxy localhost:3000
    }

    # Uploaded files from backend/storage
    handle /storage/* {
        root * /path/to/ERP/backend
        file_server
    }

    # Frontend static files (Vite build)
    handle {
        root * /path/to/ERP/frontend/dist
        try_files {path} /index.html
        file_server
    }
}
